---
import Container from "./Container.astro";
import { courses } from "../data/courses";
---

<div id="blog">
  <Container>
    <div class="mb-12 space-y-2 text-center">
      <h2 class="text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
        Nossos cursos
      </h2>
      <p class="lg:mx-auto lg:w-6/12 text-gray-600 dark:text-gray-300">
        Já temos vários cursos disponíveis para você, e estamos sempre lançando
        novos cursos, então fique ligado!
      </p>
    </div>
    <div id="courses-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        courses.map((course) => (
          <div
            data-course-card
            class="group p-6 rounded-3xl bg-white border border-gray-100 dark:shadow-none dark:border-gray-700 dark:bg-gray-800 bg-opacity-50 shadow-2xl shadow-gray-600/10"
          >
            <div class="relative overflow-hidden rounded-xl">
              <img
                src={course.image}
                alt="art cover"
                loading="lazy"
                width="1000"
                height="667"
                class="h-64 w-full object-cover object-top transition duration-500 group-hover:scale-105"
              />
            </div>
            <div class="mt-6 relative">
              <h3 class="text-2xl font-semibold text-gray-800 dark:text-white">
                {course.title}
              </h3>
              <p class="mt-6 mb-8 text-gray-600 dark:text-gray-300">
                {course.description}
              </p>
              <div class="flex items-center justify-between">
                <a class="inline-block" href={`/curso/${course.id}`}>
                  <span class="text-info text-primary dark:text-primary">
                    Mais detalhes
                  </span>
                </a>
                <a
                  href={course.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block bg-primary hover:bg-secondary text-white font-semibold py-2 px-4 rounded-md shadow-md transition-all duration-300"
                >
                  Comprar
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</div>

<script is:inline>
  (() => {
    const grid = document.getElementById("courses-grid");
    if (!grid) return;

    const daySeed = new Intl.DateTimeFormat("en-CA", {
      timeZone: "America/Sao_Paulo",
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    }).format(new Date());

    function stringToIntSeed(value) {
      let hash = 2166136261;
      for (let i = 0; i < value.length; i += 1) {
        hash ^= value.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }
      return hash >>> 0;
    }

    function mulberry32(seed) {
      let t = seed;
      return () => {
        t += 0x6d2b79f5;
        let x = Math.imul(t ^ (t >>> 15), t | 1);
        x ^= x + Math.imul(x ^ (x >>> 7), x | 61);
        return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
      };
    }

    const random = mulberry32(stringToIntSeed(daySeed));
    const cards = Array.from(grid.querySelectorAll("[data-course-card]"));
    for (let i = cards.length - 1; i > 0; i -= 1) {
      const j = Math.floor(random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }

    cards.forEach((card) => {
      grid.appendChild(card);
    });
  })();
</script>
